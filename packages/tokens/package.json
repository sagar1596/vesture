{
  "name": "@vesture/tokens",
  "version": "0.1.2",
  "description": "Themeable design token contract and reference theme for Vesture component libraries.",
  "type": "module",
  "license": "MIT",
  "author": "Sagar Bhat",
  "keywords": [
    "design-tokens",
    "theme",
    "vanilla-extract",
    "vesture"
  ],
  "homepage": "https://github.com/sagar1596/vesture/tree/main/packages/tokens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagar1596/vesture.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/sagar1596/vesture/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css.ts",
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.16.1"
  },
  "devDependencies": {
    "@vanilla-extract/esbuild-plugin": "^2.3.9",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
