{
  "name": "@vesture/react",
  "version": "0.2.7",
  "description": "React component library for Vesture, themed via @vesture/tokens.",
  "type": "module",
  "license": "MIT",
  "author": "Sagar Bhat",
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "vesture"
  ],
  "homepage": "https://www.vesture.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagar1596/vesture.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/sagar1596/vesture/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css.ts",
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@floating-ui/react": "^0.26.28",
    "@vesture/tokens": "^0.1.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vanilla-extract/esbuild-plugin": "^2.3.9",
    "@vanilla-extract/vite-plugin": "^4.0.19",
    "@vesture/theme-retro": "^0.1.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.5.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
