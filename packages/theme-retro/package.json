{
  "name": "@vesture/theme-retro",
  "version": "0.1.0",
  "description": "A warm, terracotta-and-serif retro theme implementing the @vesture/tokens contract.",
  "type": "module",
  "license": "MIT",
  "author": "Vesture Contributors",
  "keywords": ["theme", "vesture", "vanilla-extract"],
  "homepage": "https://github.com/sagar1596/vesture/tree/main/packages/theme-retro#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagar1596/vesture.git",
    "directory": "packages/theme-retro"
  },
  "bugs": {
    "url": "https://github.com/sagar1596/vesture/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css.ts",
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.16.1",
    "@vesture/tokens": "^0.1.0"
  },
  "devDependencies": {
    "@vanilla-extract/esbuild-plugin": "^2.3.9",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
